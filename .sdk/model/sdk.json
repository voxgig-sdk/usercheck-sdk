          "url": "https://docs.usercheck.com"
        },
        "description": "The UserCheck API allows you to verify the validity of a domain by sending a simple GET request to the domain endpoint. It provides responses indicating whether the domain is valid, invalid, or if rate limits have been exceeded.",
        "servers": [
          {
            "description": "Production server",
            "url": "https://api.usercheck.com"
          }
        ],
        "title": "UserCheck API",
        "version": "1.0.0",
        "tagline": "Detect disposable email domains and check domain validity in real time",
        "homepage": "https://www.usercheck.com",
        "docs_url": "https://www.usercheck.com/docs/get-started/overview",
        "about_md": "[UserCheck](https://www.usercheck.com) is a domain and email validation service designed to detect and block disposable (temporary) email addresses and domains. Its public API exposes a simple HTTP interface for checking whether a domain is valid, active, and trustworthy.\n\nWhat you get from the API:\n\n- Domain validation lookups via a `GET` request against `https://api.usercheck.com`\n- Indications of whether a domain is recognised as disposable / temporary\n- Reputation and validity signals useful for sign-up forms and lead capture\n\nThe public endpoints support CORS so they can be called from browser-based clients. The provider's own documentation also describes email validation, bulk verification, custom blocklists, and a separate signup-protection (\"Gates\") decision endpoint; consult the [official docs](https://www.usercheck.com/docs/get-started/overview) for authentication and rate-limit details.",
        "entity_desc": {
          "domain": "A domain name being checked for validity and disposable-email status against `https://api.usercheck.com`."
        },
        "auth": false
      },
